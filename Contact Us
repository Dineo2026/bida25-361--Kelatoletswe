  <!-- Contact Section -->
  <section>
    <h2>Contact Us</h2>
    <p>If you have any questions or need assistance with your booking, please reach out to us using the form below.</p>

    <form>
      <label for="name">Full Name:</label><br>
      <input type="text" id="name" name="name" required><br><br>

      <label for="email">Email Address:</label><br>
      <input type="email" id="email" name="email" required><br><br>

      <label for="message">Message:</label><br>
      <textarea id="message" name="message" rows="5" required></textarea><br><br>

      <button type="submit">Send Message</button>
    </form>

    <h3>Other Ways to Reach Us</h3>
    <p>Email: support@roombooking.com</p>
    <p>Phone: +267 123 4567</p>
    <p>Address: RoomBooking HQ, Mogoditshane, Botswana</p>
  </section>

